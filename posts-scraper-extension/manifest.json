{
  "manifest_version": 3,
  "name": "ICN Posts Scraper",
  "version": "1.0.0",
  "description": "Scrape posts from topic links in topics.json and export cumulative JSON.",
  "permissions": ["storage"],
  "host_permissions": ["https://forum.ic-network.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape ICN Posts"
  },
  "background": {
    "service_worker": "background.js"
  }
}
